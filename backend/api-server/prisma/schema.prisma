generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Using PostgreSQL for easy setup
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  organizations Organization[]
  apiKeys       ApiKey[]
}

model Organization {
  id           String @id @default(uuid())
  name         String
  solanaPubkey String @unique // The PDA of the org on Solana

  walletAddress String? // Added: backend or org-specific wallet
  issuerCount   Int     @default(0) // Added: count of active issuers

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  apiKeys       ApiKey[]
  records       HashRecord[]
  notifications Notification[]
  webhooks      Webhook[]

  createdAt DateTime @default(now())
}

model ApiKey {
  id   String @id @default(uuid())
  key  String @unique
  name String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt  DateTime      @default(now())
  lastUsedAt DateTime?
  status     String        @default("active") // Added: active / revoked
  scope      String        @default("write") // read, write, admin
  usageLogs  ApiUsageLog[]
}

model HashRecord {
  id          String @id @default(uuid())
  hash        String @unique // SHA-256 hex
  pdaAddress  String @unique
  ownerWallet String

  metadata    String?
  timestamp   Int // Unix timestamp from Solana
  expiry      Int       @default(0)
  isRevoked   Boolean   @default(false)
  txSignature String
  status      String    @default("active")
  revokedAt   DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())

  @@index([organizationId])
}

model CliSession {
  id     String @id @default(uuid())
  code   String @unique // Human readable code (e.g. 6 digits)
  status String @default("PENDING") // PENDING, AUTHORIZED, EXPIRED

  userId         String?
  organizationId String?

  token String? @unique // The generated API key

  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Notification {
  id             String   @id @default(uuid())
  organizationId String
  type           String // anchor_success, anchor_failed, key_created, key_revoked, low_balance
  title          String
  message        String
  metadata       Json? // { hash, txSignature, keyName, balance }
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, isRead])
  @@index([organizationId, createdAt])
}

model Webhook {
  id              String    @id @default(uuid())
  organizationId  String
  url             String
  secret          String // HMAC signing secret
  events          String[] // ["anchor_success", "anchor_failed", "hash_revoked"]
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  lastTriggeredAt DateTime?
  failureCount    Int       @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  logs         WebhookLog[]
}

model WebhookLog {
  id         String   @id @default(uuid())
  webhookId  String
  event      String
  payload    Json
  statusCode Int?
  response   String?
  error      String?
  duration   Int? // ms
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
}

model ApiUsageLog {
  id         String   @id @default(uuid())
  apiKeyId   String
  orgId      String
  endpoint   String // "/api/batch-register"
  method     String // "POST"
  statusCode Int
  durationMs Int
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([orgId, createdAt])
}
