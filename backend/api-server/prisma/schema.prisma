generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Using PostgreSQL for easy setup
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())

  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  organizations Organization[]
  apiKeys       ApiKey[]
  memberships   OrgMember[]
  records       HashRecord[]
}

model Organization {
  id           String @id @default(uuid())
  name         String
  solanaPubkey String @unique // The PDA of the org on Solana

  walletAddress String? // Added: backend or org-specific wallet
  issuerCount   Int     @default(0) // Added: count of active issuers

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  apiKeys       ApiKey[]
  records       HashRecord[]
  notifications Notification[]
  webhooks      Webhook[]
  webhookDeliveries WebhookDelivery[]
  members       OrgMember[]
  invites       OrgInvite[]
  auditLogs     AuditLog[]

  // Quota and Plan tracking
  plan              String   @default("free")     // free | business | enterprise
  monthlyAnchorLimit Int     @default(100)        // anchors allowed per month
  apiRateLimit      Int      @default(10)         // requests per second
  currentMonthUsage Int      @default(0)          // anchors used this month
  usageResetAt      DateTime @default(now())      // when monthly usage resets
  quotaAlertSent80  Boolean  @default(false)      // 80% alert sent this month
  quotaAlertSent95  Boolean  @default(false)      // 95% alert sent this month

  logoUrl        String?   // org logo URL for white-label certificates
  website        String?   // org website shown on certificate
  address        String?   // org address shown on certificate

  createdAt DateTime @default(now())
}

model ApiKey {
  id   String @id @default(uuid())
  key  String @unique
  name String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt  DateTime      @default(now())
  lastUsedAt DateTime?
  status     String        @default("active") // Added: active / revoked
  scope      String        @default("write") // read, write, admin
  usageLogs  ApiUsageLog[]
}

model HashRecord {
  id          String @id @default(uuid())
  hash        String @unique // SHA-256 hex
  pdaAddress  String @unique
  ownerWallet String

  metadata    String?
  timestamp   Int // Unix timestamp from Solana
  expiry      Int       @default(0)
  isRevoked   Boolean   @default(false)
  txSignature String
  status      String    @default("active")
  revokedAt   DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())

  blockNumber    BigInt?   // Solana block/slot number
  blockTimestamp DateTime? // Timestamp from Solana block
  fileSize       BigInt?   // File size in bytes
  mimeType       String?   // MIME type e.g. application/pdf
  tags           String[]  // Array of user-defined tags
  userId         String?   // User ID who anchored it
  user           User?     @relation(fields: [userId], references: [id])
  revokedBy      String?   // User ID who revoked
  revocationNote String?   // Reason for revocation
  certificateGeneratedAt DateTime?  // when certificate was first generated
  certificateCount       Int        @default(0) // how many times generated
  widgetViewCount        Int        @default(0) // times embed widget was viewed
  @@index([organizationId])
}

model CliSession {
  id     String @id @default(uuid())
  code   String @unique // Human readable code (e.g. 6 digits)
  status String @default("PENDING") // PENDING, AUTHORIZED, EXPIRED

  userId         String?
  organizationId String?

  token String? @unique // The generated API key

  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Notification {
  id             String   @id @default(uuid())
  organizationId String
  type           String // anchor_success, anchor_failed, key_created, key_revoked, low_balance
  title          String
  message        String
  metadata       Json? // { hash, txSignature, keyName, balance }
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, isRead])
  @@index([organizationId, createdAt])
}

model Webhook {
  id              String    @id @default(uuid())
  organizationId  String
  url             String
  secret          String // HMAC signing secret
  events          String[] // ["anchor_success", "anchor_failed", "hash_revoked"]
  isActive        Boolean   @default(true)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  lastTriggeredAt DateTime?
  failureCount    Int       @default(0)
  disabledAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  logs         WebhookLog[]
  deliveries   WebhookDelivery[]
}

model WebhookDelivery {
  id              String   @id @default(uuid())
  webhookId       String
  organizationId  String
  eventType       String               // e.g. anchor.confirmed
  eventId         String               // unique ID for this event instance
  payload         Json                 // full event payload sent
  status          String   @default("pending")  // pending|delivered|failed|retrying
  httpStatus      Int?                 // response status code from customer endpoint
  responseBody    String?  @db.Text    // response body from customer endpoint (truncated to 1000 chars)
  attemptCount    Int      @default(0) // how many delivery attempts made
  nextRetryAt     DateTime?            // when next retry is scheduled
  deliveredAt     DateTime?            // when first successful delivery happened
  failedAt        DateTime?            // when permanently marked as failed
  createdAt       DateTime @default(now())
  webhook         Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([organizationId])
  @@index([status])
  @@index([nextRetryAt])
  @@index([eventType])
}

model WebhookLog {
  id         String   @id @default(uuid())
  webhookId  String
  event      String
  payload    Json
  statusCode Int?
  response   String?
  error      String?
  duration   Int? // ms
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
}

model ApiUsageLog {
  id         String   @id @default(uuid())
  apiKeyId   String?
  orgId      String
  endpoint   String // "/api/batch-register"
  method     String // "POST"
  statusCode Int
  durationMs Int
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([orgId, createdAt])
}

model OrgMember {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           String       @default("member") // owner, admin, member
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model OrgInvite {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           String       @default("member") // admin, member
  token          String       @unique @default(uuid())
  invitedBy      String       // userId of inviter
  status         String       @default("pending") // pending, accepted, expired, cancelled
  createdAt      DateTime     @default(now())
  expiresAt      DateTime
  acceptedAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([token])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String       // e.g. HASH_ANCHORED, API_KEY_CREATED, MEMBER_INVITED
  category       String       // hash, key, member, org, webhook
  metadata       Json?        // flexible extra data
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
  @@index([action])
}

model IdempotencyRecord {
  id             String   @id @default(uuid())
  key            String                           // the Idempotency-Key header value
  organizationId String
  endpoint       String                           // e.g. POST /api/hashes
  requestHash    String                           // hash of request body for validation
  responseStatus Int                              // HTTP status of original response
  responseBody   Json                             // full response body stored
  createdAt      DateTime @default(now())
  expiresAt      DateTime                         // 24 hours after creation

  @@unique([key, organizationId])
  @@index([organizationId])
  @@index([expiresAt])
}
