SOLANA_RPC_URL=http://localhost:8899
SOLANA_NETWORK=localnet
PROGRAM_ID=GCR76S33jufLBugDypwrN5jKBuvBzzXnf8uimLwdQRe7
PORT=3001

# Authentication
JWT_SECRET=your-jwt-secret-here

# Database
DATABASE_URL=file:./prisma/dev.db

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL (used as CORS fallback if ALLOWED_ORIGINS is not set)
FRONTEND_URL=http://localhost:3000

# Vault Integration (optional, falls back to env vars if not set)
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=your-vault-token
# VAULT_SECRET_PATH=secret/data/sipheron/prod

# Key Management (production)
# WALLET_PRIVATE_KEY should be stored in Vault, not here
# KMS_KEY_ID=your-kms-key-id
# AWS_REGION=us-east-1

# Field-Level Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# ENCRYPTION_KEY=your-64-char-hex-key
