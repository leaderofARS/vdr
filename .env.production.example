# ─── Production Environment Template ─────────────────────
# Copy to .env and fill in real values before deployment.
# NEVER commit the filled .env file to version control.

# ─── Solana ──────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet
PROGRAM_ID=<your-deployed-program-id>

# ─── Database (PostgreSQL required in production) ────────
DATABASE_URL=postgresql://vdr:<password>@postgres:5432/sipheron_vdr
DB_PASSWORD=<strong-random-password>

# ─── Authentication ──────────────────────────────────────
JWT_SECRET=<min-64-char-random-string>

# ─── CORS ────────────────────────────────────────────────
FRONTEND_URL=https://app.sipheron.com
ALLOWED_ORIGINS=https://app.sipheron.com,https://www.sipheron.com

# ─── Field Encryption ───────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-char-hex-string>

# ─── Vault (optional, recommended) ──────────────────────
# VAULT_ADDR=https://vault.sipheron.internal:8200
# VAULT_TOKEN=<vault-token>
# VAULT_SECRET_PATH=secret/data/sipheron/prod

# ─── SipHeron API Key (for GitHub Actions) ──────────────
# SIPHERON_API_KEY=<scoped-api-key>

# ─── Dashboard ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.sipheron.com
